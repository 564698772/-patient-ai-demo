@import '../../app.wxss';

.page { padding-bottom: 40rpx; }

.sos-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 32rpx;
  background: #fef2f2;
  border-bottom: 2rpx solid #fecaca;
}

.sos-tip { font-size: 24rpx; color: #7f1d1d; }

.sos-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: #dc2626;
  color: white;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
}
.sos-btn::after { border: none; }
.sos-btn--hover { background: #b91c1c; }
.sos-icon { font-size: 26rpx; }

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #dbeafe;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text { font-size: 26rpx; color: #6b7280; }

.card {
  margin: 24rpx;
  padding: 36rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.tip-icon, .empty-icon { font-size: 72rpx; }

.tip-text, .empty-title {
  font-size: 28rpx;
  color: #111827;
  text-align: center;
}

.primary-btn {
  padding: 22rpx 48rpx;
  background: #2563eb;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}
.primary-btn::after { border: none; }

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 8rpx;
}

.list-title { font-size: 32rpx; font-weight: 700; color: #111827; }

.list-count {
  font-size: 24rpx;
  color: #2563eb;
  background: #eff6ff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.hospital-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

.hospital-item {
  display: flex;
  gap: 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.05);
  align-items: center;
}

.rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 48rpx;
  flex-shrink: 0;
}

.rank-first { background: #2563eb; color: white; }

.info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.name { font-size: 28rpx; font-weight: 600; color: #111827; }
.addr { font-size: 22rpx; color: #6b7280; }

.right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.dist-val { font-size: 36rpx; font-weight: 700; color: #2563eb; }
.dist-unit { font-size: 20rpx; color: #6b7280; }
.nav { font-size: 22rpx; color: #2563eb; font-weight: 600; }
